---
export interface Props {
  title?: string;
}


const { title = 'Sistema de Salud Ocupacional' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Favicon e iconos para todos los navegadores -->
    <link rel="icon" type="image/png" sizes="32x32" href="/icono-rapido.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icono-rapido.png" />
    <link rel="shortcut icon" href="/icono-rapido.png" />

    <!-- Apple iOS: icono de pantalla de inicio -->
    <link rel="apple-touch-icon" sizes="180x180" href="/icono-rapido.png" />
    <link rel="apple-touch-icon" href="/icono-rapido.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Colores y PWA meta tags -->
    <meta name="theme-color" content="#2563EB" />
    <meta name="msapplication-TileColor" content="#2563EB" />
    <meta name="msapplication-TileImage" content="/icono-rapido.png" />
    <meta name="application-name" content="Salud Ocupacional" />
    <meta name="apple-mobile-web-app-title" content="Salud Ocupacional" />
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">

    <title>{title}</title>

    <!-- Estilos globales para tarjetas -->
    <style is:global>
      .card {
        @apply bg-white rounded-lg shadow-lg text-gray-900 transition-colors duration-200;
      }
    </style>
    
    <style>
      /* Custom scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #f1f1f1; }
      ::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #a8a8a8; }
      
      /* Mejoras responsive para móviles */
      @media (max-width: 640px) {
        /* Evitar zoom en inputs en iOS */
        input[type="text"], 
        input[type="email"], 
        input[type="password"], 
        input[type="tel"], 
        input[type="number"], 
        textarea, 
        select {
          font-size: 16px !important;
        }
        
        /* Mejorar taps en móviles */
        button, a, [role="button"] {
          -webkit-tap-highlight-color: rgba(0,0,0,0.1);
          touch-action: manipulation;
        }
      }
      
      /* Estilos para navegación móvil */
      .mobile-menu {
        transform: translateX(-100%);
        transition: transform 0.3s ease-in-out;
      }
      
      .mobile-menu.open {
        transform: translateX(0);
      }
      
      /* Overlay para modal en móvil */
      .modal-overlay {
        backdrop-filter: blur(4px);
      }
    </style>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen transition-colors duration-200">
    <!-- SweetAlert2 CDN cargado primero -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>
    
    <!-- Script global para manejo de SweetAlert2 y errores -->
    <script>
      // Silenciar errores de WebSocket del desarrollo
      window.addEventListener('error', function(e) {
        if (e.message && (
          e.message.includes('WebSocket') || 
          e.message.includes('ERR_CONNECTION_REFUSED') ||
          e.message.includes('ws://localhost')
        )) {
          e.preventDefault();
          e.stopPropagation();
          return false;
        }
      });

      // Silenciar errores no capturados relacionados con desarrollo
      window.addEventListener('unhandledrejection', function(e) {
        if (e.reason && e.reason.toString().includes('WebSocket')) {
          e.preventDefault();
          return false;
        }
      });

      // Configurar SweetAlert2 cuando esté disponible
      document.addEventListener('DOMContentLoaded', function() {
        // Esperar a que SweetAlert2 se cargue
        const checkSwal = setInterval(function() {
          if (typeof (window as any).Swal !== 'undefined') {
            clearInterval(checkSwal);
            initializeSweetAlert();
          }
        }, 100);

        // Timeout después de 5 segundos si no se carga
        setTimeout(function() {
          clearInterval(checkSwal);
          if (typeof (window as any).Swal === 'undefined') {
            initializeSweetAlert();
          }
        }, 5000);
      });

      // ─── PWA: capturar evento de instalación lo antes posible ───────────────
      var _pwaInstallEvent: any = null;

      window.addEventListener('beforeinstallprompt', function(e: any) {
        e.preventDefault();
        _pwaInstallEvent = e;
        // Si SweetAlert ya está listo, mostrar ahora; si no, se mostrará en initializeSweetAlert
        if ((window as any).sweetAlertInitialized) {
          (window as any).showPWAInstallPrompt();
        }
      });

      function initializeSweetAlert() {
        // Evitar múltiples inicializaciones
        if ((window as any).sweetAlertInitialized) {
          return;
        }
        (window as any).sweetAlertInitialized = true;

        // Función para mostrar alertas
        (window as any).showSweetAlert = function(type, title, message, timer) {
          if (typeof (window as any).Swal !== 'undefined') {
            const config: any = {
              icon: type,
              title: title,
              text: message || '',
              confirmButtonColor: '#3B82F6'
            };
            
            if (timer) {
              config.timer = timer;
              config.showConfirmButton = false;
            }
            
            return (window as any).Swal.fire(config);
          } else {
            // Fallback a alerta nativa
            const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : type === 'warning' ? '⚠️' : 'ℹ️';
            const fullMessage = message ? `${icon} ${title}: ${message}` : `${icon} ${title}`;
            alert(fullMessage);
            return Promise.resolve();
          }
        };

        // Función para confirmaciones
        (window as any).showSweetConfirm = function(title, text, confirmText, cancelText) {
          confirmText = confirmText || 'Sí, continuar';
          cancelText = cancelText || 'Cancelar';

          if (typeof (window as any).Swal !== 'undefined') {
            return (window as any).Swal.fire({
              title: title,
              text: text,
              icon: 'question',
              showCancelButton: true,
              confirmButtonColor: '#3B82F6',
              cancelButtonColor: '#6B7280',
              confirmButtonText: confirmText,
              cancelButtonText: cancelText
            });
          } else {
            // Fallback a confirm nativo
            return Promise.resolve({
              isConfirmed: confirm(`${title}\n\n${text}`)
            });
          }
        };

        // ─── PWA Install Prompt ──────────────────────────────────────────────
        function _pwaIsStandalone() {
          return window.matchMedia('(display-mode: standalone)').matches ||
                 (window.navigator as any).standalone === true;
        }

        function _pwaIsIOS() {
          return /iphone|ipad|ipod/i.test(navigator.userAgent) && !(window as any).MSStream;
        }

        function _pwaIsSafariOnIOS() {
          return _pwaIsIOS() &&
                 /safari/i.test(navigator.userAgent) &&
                 !/chrome|crios|fxios|opios/i.test(navigator.userAgent);
        }

        function _pwaWasDismissed() {
          try {
            const ts = localStorage.getItem('pwa_dismissed_at');
            if (!ts) return false;
            const daysSince = (Date.now() - parseInt(ts)) / (1000 * 60 * 60 * 24);
            return daysSince < 7;
          } catch { return false; }
        }

        function _pwaDismiss() {
          try { localStorage.setItem('pwa_dismissed_at', String(Date.now())); } catch {}
        }

        (window as any).showPWAInstallPrompt = function() {
          if (_pwaIsStandalone() || _pwaWasDismissed()) return;
          if (typeof (window as any).Swal === 'undefined') return;

          const iosMode = _pwaIsSafariOnIOS();
          if (!iosMode && !_pwaInstallEvent) return;

          setTimeout(function() {
            if (iosMode) {
              (window as any).Swal.fire({
                title: 'Acceso rápido',
                html: `<div style="text-align:left;font-size:14px;color:#374151;line-height:1.7">
                  <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
                    <img src="/icono-rapido.png" alt="" style="width:52px;height:52px;border-radius:12px;object-fit:cover;flex-shrink:0"/>
                    <p style="margin:0">Instala <strong>Salud Ocupacional</strong> en tu iPhone/iPad para acceder con un toque.</p>
                  </div>
                  <ol style="padding-left:18px;margin:0">
                    <li style="margin-bottom:6px">Toca el botón <strong>Compartir</strong> &#x238A;</li>
                    <li style="margin-bottom:6px">Selecciona <strong>"Añadir a pantalla de inicio"</strong></li>
                    <li>Toca <strong>"Añadir"</strong></li>
                  </ol>
                </div>`,
                showCancelButton: true,
                confirmButtonText: 'Entendido',
                cancelButtonText: 'No, gracias',
                confirmButtonColor: '#2563EB',
                cancelButtonColor: '#6B7280'
              }).then(function() { _pwaDismiss(); });
            } else {
              (window as any).Swal.fire({
                title: 'Instalar acceso rápido',
                html: `<div style="text-align:center">
                  <img src="/icono-rapido.png" alt="Salud Ocupacional"
                    style="width:72px;height:72px;border-radius:16px;margin:0 auto 12px;display:block;object-fit:cover"/>
                  <p style="color:#4B5563;font-size:14px;margin:0">
                    ¿Deseas instalar <strong>Salud Ocupacional</strong> en tu dispositivo
                    para acceder desde la pantalla de inicio sin abrir el navegador?
                  </p>
                </div>`,
                showCancelButton: true,
                confirmButtonText: 'Sí, instalar',
                cancelButtonText: 'No, gracias',
                confirmButtonColor: '#2563EB',
                cancelButtonColor: '#6B7280'
              }).then(async function(result: any) {
                if (result.isConfirmed && _pwaInstallEvent) {
                  _pwaInstallEvent.prompt();
                  const choice = await _pwaInstallEvent.userChoice;
                  _pwaInstallEvent = null;
                  if (choice.outcome !== 'accepted') _pwaDismiss();
                } else {
                  _pwaDismiss();
                }
              });
            }
          }, 1500);
        };

        // Mostrar el prompt si ya se capturó el evento o si es iOS Safari
        if (_pwaInstallEvent) {
          (window as any).showPWAInstallPrompt();
        } else if (_pwaIsSafariOnIOS() && !_pwaIsStandalone() && !_pwaWasDismissed()) {
          (window as any).showPWAInstallPrompt();
        }
        // ────────────────────────────────────────────────────────────────────

      }
    </script>

    <!-- Registro del Service Worker para soporte PWA -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function() {
          navigator.serviceWorker.register('/sw.js', { scope: '/' })
            .catch(function() {});
        });
      }
    </script>

    <slot />
  </body>
</html>
