  function fileExtensionFromMime(mime: string): string {
    const m = (mime || '').toLowerCase();
    if (m.includes('webp')) return 'webp';
    if (m.includes('png')) return 'png';
    if (m.includes('jpeg') || m.includes('jpg')) return 'jpg';
    if (m.includes('avif')) return 'avif';
    return 'jpg';
  }

  function normalizeToFile(blob: Blob, filenameBase: string): File {
    if (blob instanceof File) return blob;
    const type = blob.type || 'image/jpeg';
    const ext = fileExtensionFromMime(type);
    const name = filenameBase.includes('.') ? filenameBase : `${filenameBase}.${ext}`;
    return new File([blob], name, { type });
  }

  async function uploadProfilePhotoToServer(blob: Blob, filename: string) {
    const file = normalizeToFile(blob, filename);
    const formData = new FormData();
    formData.append('photo', file);
    formData.append('patientId', patientForm.dataset.patientId || `temp_${Date.now()}`);

    const response = await fetch('/api/admin/patients/upload-photo', {
      method: 'POST',
      body: formData,
      credentials: 'include',
    });

    const contentType = response.headers.get('content-type') || '';
    let result: any = null;
    if (contentType.includes('application/json')) {
      try {
        result = await response.json();
      } catch {
        result = null;
      }
    }

    if (!response.ok) {
      if (result && typeof result === 'object') {
        throw new Error(String(result.message || result.error || 'Error al subir foto'));
      }
      const text = await response.text().catch(() => '');
      throw new Error(text || 'Error al subir foto');
    }

    if (!result || typeof result !== 'object' || !result.success) {
      throw new Error(String(result?.message || result?.error || 'Error al subir foto'));
    }
    return String(result.data?.key || result.data?.url || result.data?.path || '');
  }

  async function uploadSignatureToServer(blob: Blob, filename: string) {
    const file = normalizeToFile(blob, filename);
    const formData = new FormData();
    formData.append('signature', file);
    formData.append('patientId', patientForm.dataset.patientId || `temp_${Date.now()}`);

    const response = await fetch('/api/admin/patients/upload-signature', {
      method: 'POST',
      body: formData,
      credentials: 'include',
    });

    const contentType = response.headers.get('content-type') || '';
    let result: any = null;
    if (contentType.includes('application/json')) {
      try {
        result = await response.json();
      } catch {
        result = null;
      }
    }

    if (!response.ok) {
      if (result && typeof result === 'object') {
        throw new Error(String(result.message || result.error || 'Error al subir firma'));
      }
      const text = await response.text().catch(() => '');
      throw new Error(text || 'Error al subir firma');
    }

    if (!result || typeof result !== 'object' || !result.success) {
      throw new Error(String(result?.message || result?.error || 'Error al subir firma'));
    }
    return String(result.data?.key || result.data?.url || result.data?.path || '');
  }

