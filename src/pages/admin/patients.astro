  // Cargar empresas en el selector de empresa
  async function loadCompaniesIntoSelect(selectedId = '') {
    const companySelect = document.getElementById('companySelect') as HTMLSelectElement | null;
    if (!companySelect) return;

    try {
      const resp = await fetch('/api/admin/companies');
      let data: any = null;
      try {
        data = await resp.json();
      } catch (parseError) {
      }

      if (!resp.ok || !data || !data.success || !Array.isArray(data.data)) {
        if (resp.status === 401) {
          showAlert(
            'error',
            'Sin permisos para empresas',
            'No tienes permisos para cargar el listado de empresas. Puedes escribir el nombre manualmente en el campo de empresa.'
          );
        } else {
          showAlert(
            'error',
            'Error al cargar empresas',
            'No se pudieron cargar las empresas. Puedes escribir el nombre manualmente en el campo de empresa.'
          );
        }
        companySelect.innerHTML = '<option value="">Particular / Sin empresa</option>';
        companySelect.value = '';
        syncCompanyInputState();
        return;
      }

      companySelect.innerHTML = '<option value="">Particular / Sin empresa</option>';
      data.data.forEach((c: any) => {
        const opt = document.createElement('option');
        opt.value = String(c.id);
        opt.textContent = c.name;
        companySelect.appendChild(opt);
      });
      companySelect.value = selectedId || '';
      syncCompanyInputState();
    } catch (err) {
      showAlert(
        'error',
        'Error de conexión',
        'No se pudieron cargar las empresas por un problema de conexión. Puedes escribir el nombre manualmente en el campo de empresa.'
      );
      companySelect.innerHTML = '<option value="">Particular / Sin empresa</option>';
      companySelect.value = '';
      syncCompanyInputState();
    }
  }

