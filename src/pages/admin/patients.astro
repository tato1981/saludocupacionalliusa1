  function setProfilePhotoPreview(storedValue: string | null, nameForFallback?: string) {
    const cleaned = (storedValue || '').trim();
    const initial = getNameInitial(nameForFallback);
    if (!cleaned || cleaned.startsWith('blob:') || cleaned.startsWith('data:')) {
      profilePhotoUrlInput.value = '';
