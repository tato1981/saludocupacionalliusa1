---
import DashboardLayout from '@/components/layout/DashboardLayout.astro';
import CameraCapture from '@/components/ui/CameraCapture.astro';
import SignaturePad from '@/components/ui/SignaturePad.astro';
import { requireAuth, hasRole } from '@/lib/auth';

// Verificar autenticación y rol de admin o staff
const user = requireAuth(Astro.cookies);
if (!hasRole(user, 'staff')) {
  return Astro.redirect('/auth/login');
}
---

<DashboardLayout title="Gestión de Pacientes - Panel Admin" user={user}>
  <div class="space-y-6">
    <!-- Encabezado de página -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
        <span class="hidden sm:inline">👥 Gestión de Pacientes</span>
        <span class="sm:hidden">👥 Pacientes</span>
      </h1>
      <button
        id="newPatientBtn"
        class="mt-4 sm:mt-0 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium flex items-center justify-center text-sm sm:text-base">
        <span class="hidden sm:inline">+ Nuevo Paciente</span>
        <span class="sm:hidden">+ Nuevo</span>
      </button>
    </div>
      
      <!-- Estadísticas rápidas responsive -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6">
        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-blue-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Total Pacientes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="totalPatients">-</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-3 sm:p-6 rounded-lg shadow">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-green-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Citas Hoy</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="todayAppointments">-</p>
            </div>
          </div>
        </div>

        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-yellow-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Pendientes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="pendingAppointments">-</p>
            </div>
          </div>
        </div>

        <div class="card p-3 sm:p-6">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-purple-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Nuevos Este Mes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="newThisMonth">-</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Filtros y búsqueda responsive -->
      <div class="card p-4 sm:p-6 mb-6">
        <div class="flex flex-col space-y-4 lg:flex-row lg:items-center lg:justify-between lg:space-y-0">
          <div class="flex-1 max-w-lg">
            <div class="relative">
              <input 
                type="text" 
                id="searchInput"
                placeholder="Buscar por nombre, documento o email..."
                class="w-full pl-10 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              />
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-3">
            <select id="genderFilter" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500">
              <option value="">Todos los géneros</option>
              <option value="masculino">Masculino</option>
              <option value="femenino">Femenino</option>
              <option value="otro">Otro</option>
            </select>
            <button 
              id="refreshBtn"
              class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg transition-colors text-sm"
            >
              <span class="hidden sm:inline">🔄 Actualizar</span>
              <span class="sm:hidden">🔄</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Lista de pacientes -->
      <div class="card overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Lista de Pacientes</h2>
        </div>
        
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paciente</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contacto</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Edad/Género</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Empresa</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Última Cita</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody id="patientsTableBody" class="bg-white divide-y divide-gray-200">
              <!-- Se carga dinámicamente -->
            </tbody>
          </table>
        </div>
        
        <!-- Loading state -->
        <div id="loadingState" class="text-center py-8">
          <div class="inline-flex items-center">
            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Cargando pacientes...
          </div>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
          <span class="text-sm text-gray-700" id="resultsCount">Mostrando 0 resultados</span>
          <div class="flex space-x-2">
            <button id="prevBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Anterior</button>
            <button id="nextBtn" class="px-3 py-1 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50" disabled>Siguiente</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal para nuevo paciente responsive -->
  <div id="patientModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 modal-overlay">
    <div class="relative top-4 sm:top-20 mx-auto p-4 sm:p-5 border w-full max-w-5xl shadow-lg rounded-md bg-white my-4 sm:my-0">
      <div class="mt-3">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base sm:text-lg font-medium text-gray-900" id="modalTitle">Nuevo Paciente</h3>
          <button id="closeModal" class="text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        
        <form id="patientForm" class="space-y-4">
          <input type="hidden" name="profilePhotoUrl" id="profilePhotoUrl" />
          <input type="hidden" name="signatureUrl" id="signatureUrl" />
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 items-start">
            <div class="flex items-center gap-4">
              <div class="h-16 w-16 rounded-full bg-gray-200 border border-gray-300 overflow-hidden flex items-center justify-center">
                <img id="profilePhotoPreview" class="h-full w-full object-cover hidden" alt="Foto de perfil" />
                <span id="profilePhotoFallback" class="text-xl font-semibold text-gray-600">?</span>
              </div>
              <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Foto de Perfil (opcional)</label>
                <input id="profilePhotoFile" type="file" accept="image/*" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                <div class="mt-2 flex gap-2">
                  <button type="button" id="removeProfilePhotoBtn" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 text-sm">
                    Quitar foto
                  </button>
                </div>
              </div>
            </div>
            <div class="lg:col-span-2">
              <CameraCapture className="mt-1" />
            </div>
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 items-start">
            <div class="flex items-start gap-4">
              <div class="h-16 w-28 rounded bg-gray-200 border border-gray-300 overflow-hidden flex items-center justify-center">
                <img id="signaturePreview" class="h-full w-full object-contain hidden" alt="Firma del paciente" />
                <span id="signatureFallback" class="text-xs font-medium text-gray-600 px-2 text-center">Sin firma</span>
              </div>
              <div class="flex-1">
                <label class="block text-sm font-medium text-gray-700 mb-1">Firma del Paciente (opcional)</label>
                <input id="signatureFile" type="file" accept="image/*" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                <div class="mt-2 flex gap-2">
                  <button type="button" id="removeSignatureBtn" class="px-3 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 text-sm">
                    Quitar firma
                  </button>
                </div>
              </div>
            </div>
            <div class="lg:col-span-2">
              <SignaturePad className="mt-1" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nombre Completo *</label>
              <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input type="email" name="email" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
              <input type="tel" name="phone" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Documento *</label>
              <select name="documentType" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="cedula">Cédula</option>
                <option value="pasaporte">Pasaporte</option>
                <option value="tarjeta_identidad">Tarjeta de Identidad</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Número de Documento *</label>
              <input type="text" name="documentNumber" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Fecha de Nacimiento *</label>
              <input type="date" id="dateOfBirth" name="dateOfBirth" required max="" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
              <p class="text-xs text-gray-500 mt-1">La fecha de nacimiento no puede ser mayor a la fecha actual</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Género *</label>
              <select name="gender" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="masculino">Masculino</option>
                <option value="femenino">Femenino</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Sangre</label>
              <select name="bloodType" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="">Seleccionar...</option>
                <option value="A+">A+</option>
                <option value="A-">A-</option>
                <option value="B+">B+</option>
                <option value="B-">B-</option>
                <option value="AB+">AB+</option>
                <option value="AB-">AB-</option>
                <option value="O+">O+</option>
                <option value="O-">O-</option>
              </select>
            </div>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
            <textarea name="address" rows="2" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"></textarea>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Ocupación</label>
              <input type="text" name="occupation" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Empresa (opcional)</label>
              <select name="companyId" id="companySelect" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <option value="">Particular / Sin empresa</option>
              </select>
              <small class="text-xs text-gray-500">Si no aparece en la lista, puede escribirla abajo.</small>
              <input type="text" name="company" placeholder="Nombre de empresa (opcional)" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Contacto de Emergencia</label>
              <input type="text" name="emergencyContactName" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono de Emergencia</label>
              <input type="tel" name="emergencyContactPhone" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
          </div>
          
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Alergias</label>
              <textarea name="allergies" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Describe las alergias conocidas..."></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Medicamentos Actuales</label>
              <textarea name="medications" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Lista de medicamentos que toma actualmente..."></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Condiciones Médicas</label>
              <textarea name="medicalConditions" rows="3" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Condiciones médicas existentes..."></textarea>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row justify-end space-y-3 sm:space-y-0 sm:space-x-3 pt-4">
            <button type="button" id="cancelBtn" class="w-full sm:w-auto px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 text-sm">
              Cancelar
            </button>
            <button type="submit" class="w-full sm:w-auto px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 text-sm">
              <span id="submitBtnText">Guardar Paciente</span>
              <svg id="submitBtnLoader" class="hidden animate-spin -mr-1 ml-3 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Comentarios de depuración limpiados
  let currentPatients: any[] = [];
  let currentPage = 1;
  const itemsPerPage = 10;

  function r2ProxyUrlForStoredValue(value: string): string {
    if (!value) return '';
    if (value.startsWith('blob:') || value.startsWith('data:')) return '';
    if (value.startsWith('http://') || value.startsWith('https://')) {
      try {
        const u = new URL(value);
        if (u.hostname.endsWith('r2.dev') && u.pathname && u.pathname !== '/') {
          return `/api/files/r2?key=${encodeURIComponent(u.pathname.replace(/^\/+/, ''))}`;
        }
      } catch {}
      return value;
    }
    return `/api/files/r2?key=${encodeURIComponent(value)}`;
  }

  // Cargar estadísticas
  async function loadStatistics() {
    const safeFetchJson = async (url: string) => {
      try {
        const resp = await fetch(url);
        if (!resp.ok) {
          return null;
        }
        try {
          return await resp.json();
        } catch {
          return null;
        }
      } catch {
        return null;
      }
    };

    const [patientStats, appointmentStats] = await Promise.all([
      safeFetchJson('/api/admin/patients/stats'),
      safeFetchJson('/api/admin/appointments/stats')
    ]);

    if (patientStats && patientStats.success && patientStats.data) {
      const totalPatientsEl = document.getElementById('totalPatients');
      const newThisMonthEl = document.getElementById('newThisMonth');
      if (totalPatientsEl) totalPatientsEl.textContent = String(patientStats.data.totalPatients ?? '-');
      if (newThisMonthEl) newThisMonthEl.textContent = String(patientStats.data.newThisMonth ?? '-');
    }

    if (appointmentStats && appointmentStats.success && appointmentStats.data) {
      const todayAppointmentsEl = document.getElementById('todayAppointments');
      const pendingAppointmentsEl = document.getElementById('pendingAppointments');
      if (todayAppointmentsEl) {
        todayAppointmentsEl.textContent = String(appointmentStats.data.todayTotal ?? '-');
      }
      if (pendingAppointmentsEl) {
        const total = Number(appointmentStats.data.todayTotal ?? 0);
        const completed = Number(appointmentStats.data.todayCompleted ?? 0);
        pendingAppointmentsEl.textContent = String(total - completed);
      }
    }
  }

  // Cargar pacientes
  async function loadPatients(searchTerm = '') {
    const loadingState = document.getElementById('loadingState')!;
    const tableBody = document.getElementById('patientsTableBody')!;
    
    loadingState.classList.remove('hidden');
    
    try {
      const url = searchTerm 
        ? `/api/admin/patients/search?q=${encodeURIComponent(searchTerm)}`
        : '/api/admin/patients';
      
      const response = await fetch(url);
      const data = await response.json();
      
      if (data.success) {
        currentPatients = data.data;
        renderPatients(currentPatients);
      }
    } catch (error) {
      // Silently fail
    } finally {
      loadingState.classList.add('hidden');
    }
  }

  // Renderizar pacientes en la tabla
  function renderPatients(patients: any[]) {
    const tableBody = document.getElementById('patientsTableBody')!;
    const countSpan = document.getElementById('resultsCount')!;
    const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
    const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
    
    // Pagination Logic
    const totalPages = Math.ceil(patients.length / itemsPerPage);
    
    // Ensure currentPage is valid
    if (currentPage < 1) currentPage = 1;
    if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
    
    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const paginatedItems = patients.slice(start, end);

    if (patients.length === 0) {
      countSpan.textContent = 'Mostrando 0 resultados';
      tableBody.innerHTML = `
        <tr>
          <td colspan="7" class="px-6 py-8 text-center text-gray-500">
            No se encontraron pacientes
          </td>
        </tr>
      `;
      prevBtn.disabled = true;
      nextBtn.disabled = true;
      return;
    }

    countSpan.textContent = `Mostrando ${start + 1}-${Math.min(end, patients.length)} de ${patients.length} resultados`;

    // Update buttons
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;

    // Remove existing event listeners (to avoid duplicates)
    const newPrevBtn = prevBtn.cloneNode(true);
    const newNextBtn = nextBtn.cloneNode(true);
    prevBtn.parentNode!.replaceChild(newPrevBtn, prevBtn);
    nextBtn.parentNode!.replaceChild(newNextBtn, nextBtn);
    
    // Add event listeners
    newPrevBtn.addEventListener('click', () => {
        if (currentPage > 1) {
            currentPage--;
            renderPatients(patients);
        }
    });

    newNextBtn.addEventListener('click', () => {
        if (currentPage < totalPages) {
            currentPage++;
            renderPatients(patients);
