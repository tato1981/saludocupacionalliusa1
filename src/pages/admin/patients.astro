    profilePhotoUrlInput.value = cleaned;
    profilePhotoPreview.src = resolveProfilePhotoSrc(cleaned);
    profilePhotoPreview.classList.remove('hidden');
    profilePhotoFallback.classList.add('hidden');
  }

