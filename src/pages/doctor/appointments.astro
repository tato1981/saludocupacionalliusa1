---
import Layout from '../../layouts/Layout.astro';
import { requireAuth } from '../../lib/auth';

// Verificar autenticación y rol de doctor
const user = requireAuth(Astro.cookies);
if (!user || user.role !== 'doctor') {
  return Astro.redirect('/auth/login');
}
---

<Layout title="Mis Citas - Panel Doctor">
  <div class="min-h-screen bg-gray-50">
    <!-- Header Responsive -->
    <div class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center py-4 lg:py-6">
          <div class="flex items-center space-x-2 sm:space-x-4 mb-4 sm:mb-0">
            <a href="/dashboard" class="text-gray-500 hover:text-gray-700">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </a>
            <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Mis Citas Médicas</h1>
          </div>
          <div class="text-right">
            <div class="text-sm text-gray-600">
              Dr. <span class="font-medium">{user.name}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      
      <!-- Estadísticas rápidas del doctor responsive -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6">
        <div class="bg-white p-3 sm:p-6 rounded-lg shadow">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-blue-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Citas Hoy</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="todayAppointments">-</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-3 sm:p-6 rounded-lg shadow">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-green-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Completadas</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="completedAppointments">-</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-3 sm:p-6 rounded-lg shadow">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-yellow-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Pendientes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="pendingAppointments">-</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-3 sm:p-6 rounded-lg shadow">
          <div class="flex items-center">
            <div class="p-1 sm:p-2 bg-purple-100 rounded-lg">
              <svg class="w-4 h-4 sm:w-6 sm:h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <div class="ml-2 sm:ml-4">
              <p class="text-xs sm:text-sm font-medium text-gray-600">Total Pacientes</p>
              <p class="text-lg sm:text-2xl font-bold text-gray-900" id="totalPatients">-</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Próximas citas -->
      <div class="bg-white rounded-lg shadow mb-6">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Próximas Citas</h2>
        </div>
        <div class="p-6">
          <div id="upcomingAppointments" class="space-y-4">
            <!-- Se cargan dinámicamente -->
          </div>
          <div id="noUpcomingAppointments" class="hidden text-center py-8 text-gray-500">
            <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p>No tienes citas programadas para los próximos días</p>
          </div>
        </div>
      </div>

      <!-- Filtros y controles responsive -->
      <div class="bg-white p-4 sm:p-6 rounded-lg shadow mb-6">
        <div class="flex flex-col space-y-4 lg:flex-row lg:items-center lg:justify-between lg:space-y-0">
          <div class="flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-4 flex-1">
            <div class="relative flex-1 sm:max-w-xs">
              <input
                type="text"
                id="searchDocument"
                placeholder="Buscar por documento..."
                class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 w-full text-sm"
              />
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
            </div>
            <select id="statusFilter" class="border border-gray-300 rounded px-3 py-2 text-sm">
              <option value="">Todos los estados</option>
              <option value="programada">Programadas</option>
              <option value="en_progreso">En progreso</option>
              <option value="completada">Completadas</option>
              <option value="cancelada">Canceladas</option>
            </select>
            <input
              type="date"
              id="dateFilter"
              class="border border-gray-300 rounded px-3 py-2 text-sm"
            />
          </div>
          <div class="flex justify-center sm:justify-end">
            <button
              id="refreshBtn"
              class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-4 py-2 rounded-lg transition-colors text-sm"
            >
              <span class="hidden sm:inline">🔄 Actualizar</span>
              <span class="sm:hidden">🔄</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Lista de todas las citas -->
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
          <h2 class="text-lg font-medium text-gray-900">Todas Mis Citas</h2>
        </div>
        
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fecha/Hora</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Paciente</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tipo de Cita</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Estado</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Motivo</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Acciones</th>
              </tr>
            </thead>
            <tbody id="appointmentsTableBody" class="bg-white divide-y divide-gray-200">
              <!-- Se carga dinámicamente -->
            </tbody>
          </table>
        </div>

        <!-- Loading state -->
        <div id="loadingState" class="text-center py-8">
          <div class="inline-flex items-center">
            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Cargando citas...
          </div>
        </div>

        <!-- Paginación -->
        <div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <span class="text-sm text-gray-700" id="resultsCount">Mostrando 0 resultados</span>
          <div class="flex items-center justify-center sm:justify-end space-x-1 flex-wrap gap-1" id="paginationContainer">
            <button id="prevBtn" class="px-2 sm:px-3 py-1 border border-gray-300 rounded-md text-xs sm:text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors" disabled>Anterior</button>
            <div id="pageNumbers" class="flex items-center space-x-1 mx-1 sm:mx-2">
              <!-- Los números de página se generan dinámicamente -->
            </div>
            <button id="nextBtn" class="px-2 sm:px-3 py-1 border border-gray-300 rounded-md text-xs sm:text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors" disabled>Siguiente</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Emitir Concepto -->
  <div id="issueModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
      <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" onclick="closeModal()"></div>
      <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
      <div class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
        <form id="issueForm" onsubmit="handleIssueSubmit(event)">
          <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
            <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">Emitir Certificado de Aptitud</h3>
            
            <input type="hidden" id="modalPatientId" name="patientId">
            <input type="hidden" id="modalAppointmentId" name="appointmentId">
            
            <div class="mt-4 space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700">Paciente</label>
                <input type="text" id="modalPatientName" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm bg-gray-50 text-gray-500 sm:text-sm" readonly>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700">Concepto de Aptitud *</label>
                <select id="modalAptitude" name="aptitudeStatus" required class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                  <option value="">Seleccione...</option>
                  <option value="apto">APTO</option>
                  <option value="apto_con_restricciones">APTO CON RESTRICCIONES</option>
                  <option value="apto_manipulacion_alimentos">APTO PARA MANIPULACIÓN DE ALIMENTOS</option>
                  <option value="apto_trabajo_alturas">APTO PARA TRABAJO EN ALTURAS</option>
                  <option value="apto_espacios_confinados">APTO PARA ESPACIOS CONFINADOS</option>
                  <option value="apto_conduccion">APTO PARA CONDUCCIÓN</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700">Restricciones</label>
                <textarea id="modalRestrictions" name="restrictions" rows="3" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Describa las restricciones si aplica..."></textarea>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700">Recomendaciones</label>
                <textarea id="modalRecommendations" name="recommendations" rows="3" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Recomendaciones de salud ocupacional..."></textarea>
              </div>

              <div class="grid grid-cols-2 gap-4">
                 <div>
                    <label class="block text-sm font-medium text-gray-700">Inicio Vigencia</label>
                    <input type="date" id="modalStart" name="validityStart" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                 </div>
                 <div>
                    <label class="block text-sm font-medium text-gray-700">Fin Vigencia</label>
                    <input type="date" id="modalEnd" name="validityEnd" class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                 </div>
              </div>
            </div>
          </div>
          <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
            <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
              Emitir y Finalizar
            </button>
            <button type="button" onclick="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
              Cancelar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  let allAppointments: any[] = [];
  let filteredAppointments: any[] = [];
  let currentPage = 1;
  const itemsPerPage = 10;

  // Función helper para mostrar alertas usando SweetAlert2 global
  function showAlert(type: 'success' | 'error' | 'warning' | 'info', title: string, message?: string) {
    // Usar las funciones globales de SweetAlert2
    if (typeof (window as any).showSweetAlert === 'function') {
      const timer = type === 'success' ? 2000 : undefined;
      return (window as any).showSweetAlert(type, title, message, timer);
    } else {
      // Fallback a alerta nativa
      const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : type === 'warning' ? '⚠️' : 'ℹ️';
      const fullMessage = message ? `${icon} ${title}: ${message}` : `${icon} ${title}`;
      alert(fullMessage);
      return Promise.resolve();
    }
  }

  // Cargar citas del doctor
  async function loadAppointments() {
    const loadingState = document.getElementById('loadingState')!;
    const tableBody = document.getElementById('appointmentsTableBody')!;

    loadingState.classList.remove('hidden');

    try {
      const response = await fetch('/api/doctor/appointments');
      const data = await response.json();

      if (data.success) {
        allAppointments = data.data;
        filteredAppointments = [...allAppointments];
        renderAppointments(filteredAppointments);
        updateStatistics(allAppointments);
        renderUpcomingAppointments(allAppointments);
      }
    } catch (error) {
      // Silently fail
    } finally {
      loadingState.classList.add('hidden');
    }
  }

  // Actualizar estadísticas
  function updateStatistics(appointments: any[]) {
    const today = new Date().toISOString().split('T')[0];
    
    const todayAppointments = appointments.filter(app => 
      app.appointment_date.split(' ')[0] === today
    );
    
    const completed = appointments.filter(app => app.status === 'completada');
    const pending = appointments.filter(app => 
      app.status === 'programada' && new Date(app.appointment_date) >= new Date()
    );
    
    // Contar pacientes únicos
    const uniquePatients = new Set(appointments.map(app => app.patient_id));
    
    document.getElementById('todayAppointments')!.textContent = todayAppointments.length.toString();
    document.getElementById('completedAppointments')!.textContent = completed.length.toString();
    document.getElementById('pendingAppointments')!.textContent = pending.length.toString();
    document.getElementById('totalPatients')!.textContent = uniquePatients.size.toString();
  }

  // Renderizar próximas citas
  function renderUpcomingAppointments(appointments: any[]) {
    const upcomingContainer = document.getElementById('upcomingAppointments')!;
    const noUpcoming = document.getElementById('noUpcomingAppointments')!;
    
    const upcoming = appointments
      .filter(app => 
        app.status === 'programada' && 
        new Date(app.appointment_date) >= new Date()
      )
      .sort((a, b) => new Date(a.appointment_date).getTime() - new Date(b.appointment_date).getTime())
      .slice(0, 5);

    if (upcoming.length === 0) {
      upcomingContainer.classList.add('hidden');
      noUpcoming.classList.remove('hidden');
      return;
    }

    upcomingContainer.classList.remove('hidden');
    noUpcoming.classList.add('hidden');

    upcomingContainer.innerHTML = upcoming.map(appointment => `
      <div class="border border-gray-200 rounded-lg p-4">
        <div class="flex justify-between items-start">
          <div>
            <h4 class="font-medium text-gray-900">${appointment.patient_name}</h4>
            <p class="text-sm text-gray-600 mt-1">
              ${appointment.appointment_type || 'Consulta general'}
            </p>
            <p class="text-sm text-gray-600">
              ${new Date(appointment.appointment_date).toLocaleDateString('es-ES', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })} - ${new Date(appointment.appointment_date).toLocaleTimeString('es-ES', {
                hour: '2-digit',
                minute: '2-digit'
              })}
            </p>
            <p class="text-sm text-gray-500 mt-1">
              ${appointment.patient_company || 'Sin empresa'} • ${appointment.patient_document}
            </p>
          </div>
          <div class="flex space-x-2">
            <button 
              onclick="startAppointment(${appointment.id})"
              class="text-green-600 hover:text-green-800 text-sm font-medium"
            >
              Iniciar
            </button>
            <button 
              onclick="viewPatientDetails(${appointment.patient_id})"
              class="text-blue-600 hover:text-blue-800 text-sm font-medium"
            >
              Ver Paciente
            </button>
          </div>
        </div>
      </div>
    `).join('');
  }

  // Renderizar números de página
  function renderPageNumbers(totalPages: number) {
    const pageNumbersContainer = document.getElementById('pageNumbers')!;
    pageNumbersContainer.innerHTML = '';

    if (totalPages <= 1) return;

    const createPageButton = (pageNum: number, isActive: boolean = false) => {
      const button = document.createElement('button');
      button.textContent = pageNum.toString();
      button.className = `px-2 sm:px-3 py-1 text-xs sm:text-sm font-medium rounded-md transition-colors ${
        isActive
          ? 'bg-blue-600 text-white'
          : 'bg-white text-gray-700 border border-gray-300 hover:bg-gray-50'
      }`;
      button.onclick = () => {
        currentPage = pageNum;
        renderAppointments(filteredAppointments);
        // Scroll hacia arriba de la tabla
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };
      return button;
    };

    const createDots = () => {
      const dots = document.createElement('span');
      dots.textContent = '...';
      dots.className = 'px-1 sm:px-2 text-gray-500 text-xs sm:text-sm';
      return dots;
    };

    // Lógica para mostrar 1, 2, 3, ..., última página
    if (totalPages <= 5) {
      // Si hay 5 o menos páginas, mostrar todas
      for (let i = 1; i <= totalPages; i++) {
        pageNumbersContainer.appendChild(createPageButton(i, i === currentPage));
      }
    } else {
      // Mostrar las primeras 3 páginas
      for (let i = 1; i <= 3; i++) {
        pageNumbersContainer.appendChild(createPageButton(i, i === currentPage));
      }

      // Mostrar puntos suspensivos
      pageNumbersContainer.appendChild(createDots());

      // Mostrar la última página
      pageNumbersContainer.appendChild(createPageButton(totalPages, totalPages === currentPage));
    }
  }

  // Renderizar tabla de citas
  function renderAppointments(appointments: any[]) {
    const tableBody = document.getElementById('appointmentsTableBody')!;
    const countSpan = document.getElementById('resultsCount')!;
    const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
    const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;

    // Calcular paginación
    const totalPages = Math.ceil(appointments.length / itemsPerPage);

    // Asegurar que currentPage es válido
    if (currentPage < 1) currentPage = 1;
    if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;

    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const paginatedItems = appointments.slice(start, end);

    // Actualizar contador
    if (appointments.length === 0) {
      countSpan.textContent = 'Mostrando 0 resultados';
      tableBody.innerHTML = `
        <tr>
          <td colspan="6" class="px-6 py-8 text-center text-gray-500">
            No se encontraron citas
          </td>
        </tr>
      `;
      prevBtn.disabled = true;
      nextBtn.disabled = true;
      document.getElementById('pageNumbers')!.innerHTML = '';
      return;
    }

    countSpan.textContent = `Mostrando ${start + 1}-${Math.min(end, appointments.length)} de ${appointments.length} resultados`;

    // Actualizar botones
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;

    // Renderizar números de página
    renderPageNumbers(totalPages);

    tableBody.innerHTML = paginatedItems.map(appointment => {
      const status = appointment.status.toLowerCase();
      const hasCertificate = appointment.certificate_id && appointment.certificate_id > 0;
      
      return `
      <tr class="hover:bg-gray-50">
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
          <div>
            ${new Date(appointment.appointment_date).toLocaleDateString('es-ES')}
          </div>
          <div class="text-gray-500">
            ${new Date(appointment.appointment_date).toLocaleTimeString('es-ES', {
              hour: '2-digit',
              minute: '2-digit'
            })}
          </div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <div class="flex items-center">
            ${appointment.patient_photo_path ? `
              <img 
                src="${appointment.patient_photo_path}" 
                alt="Foto de ${appointment.patient_name}"
                class="w-12 h-12 rounded-full object-cover mr-3 shadow-sm border border-gray-200"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
              />
              <div class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center mr-3 shadow-sm border border-gray-200" style="display: none;">
                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
            ` : `
              <div class="w-12 h-12 rounded-full bg-gray-200 flex items-center justify-center mr-3 shadow-sm border border-gray-200">
                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
            `}
            <div>
              <div class="text-sm font-medium text-gray-900">${appointment.patient_name}</div>
              <div class="text-sm text-gray-500">${appointment.patient_document}</div>
              <div class="text-sm text-gray-500">${appointment.patient_company || 'Sin empresa'}</div>
            </div>
          </div>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
          ${appointment.appointment_type || 'Consulta general'}
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <span class="px-2 py-1 text-xs font-medium rounded-full ${getStatusBadgeClass(status)}">
            ${getStatusText(status)}
          </span>
        </td>
        <td class="px-6 py-4 text-sm text-gray-500 max-w-xs truncate">
          ${appointment.reason || '-'}
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
          <div class="flex space-x-2 items-center">
            ${status === 'programada' ? 
              `<button onclick="changeAppointmentStatus(${appointment.id}, 'en_progreso')" class="text-green-600 hover:text-green-900 font-medium">▶ Iniciar</button>` :
              status === 'en_progreso' ? 
              `<button onclick="openIssueModal(${appointment.id})" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Completar y Emitir
              </button>` :
              ''
            }
            
            ${status === 'completada' ? 
                (hasCertificate ? 
                    `<div class="flex flex-col space-y-1">
                        <a href="/api/certificates/download?code=${appointment.verification_code}" target="_blank" class="inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded-md text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 shadow-sm transition-colors duration-200 w-full justify-center">
                           <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                           Ver Certificado
                        </a>
                        <button onclick="openIssueModal(${appointment.id})" class="inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 shadow-sm transition-colors duration-200 w-full justify-center" title="Generar nuevo certificado (sobrescribe el anterior)">
                           <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                           Regenerar
                        </button>
                    </div>` :
                    `<button onclick="openIssueModal(${appointment.id})" class="inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 shadow-sm transition-colors duration-200">
                       <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                       Generar Certificado
                    </button>`
                ) : ''
            }

            <button onclick="viewPatientDetails(${appointment.patient_id})" class="inline-flex items-center justify-center p-2 border border-transparent rounded-md text-white bg-blue-600 hover:bg-blue-700 shadow-sm transition-colors ml-2" title="Ver Detalles del Paciente">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
            </button>
            
            ${(status === 'programada' || status === 'en_progreso') ? 
              `<button onclick="changeAppointmentStatus(${appointment.id}, 'cancelada')" class="text-red-600 hover:text-red-900 ml-2" title="Cancelar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>` :
              ''
            }
          </div>
        </td>
      </tr>
      `;
    }).join('');
  }

  // Obtener clase CSS para el estado
  function getStatusBadgeClass(status: string): string {
    switch (status) {
      case 'programada': return 'bg-blue-100 text-blue-800';
      case 'en_progreso': return 'bg-yellow-100 text-yellow-800';
      case 'completada': return 'bg-green-100 text-green-800';
      case 'cancelada': return 'bg-red-100 text-red-800';
      case 'no_asistio': return 'bg-gray-100 text-gray-800';
      default: return 'bg-gray-100 text-gray-800';
    }
  }

  // Obtener texto del estado
  function getStatusText(status: string): string {
    switch (status) {
      case 'programada': return 'Programada';
      case 'en_progreso': return 'En progreso';
      case 'completada': return 'Completada';
      case 'cancelada': return 'Cancelada';
      case 'no_asistio': return 'No asistió';
      default: return status;
    }
  }

  // Filtros
  const statusFilter = document.getElementById('statusFilter') as HTMLSelectElement;
  const dateFilter = document.getElementById('dateFilter') as HTMLInputElement;
  const searchDocument = document.getElementById('searchDocument') as HTMLInputElement;

  function applyFilters() {
    let filtered = [...allAppointments];

    // Filtro por búsqueda de documento
    if (searchDocument.value) {
      const searchTerm = searchDocument.value.toLowerCase();
      filtered = filtered.filter(app =>
        app.patient_document?.toLowerCase().includes(searchTerm) ||
        app.patient_name?.toLowerCase().includes(searchTerm)
      );
    }

    // Filtro por estado
    if (statusFilter.value) {
      filtered = filtered.filter(app => app.status === statusFilter.value);
    }

    // Filtro por fecha
    if (dateFilter.value) {
      filtered = filtered.filter(app => {
        try {
          const appDate = new Date(app.appointment_date);
          return !isNaN(appDate.getTime()) && appDate.toISOString().split('T')[0] === dateFilter.value;
        } catch (e) {
          return false;
        }
      });
    }

    filteredAppointments = filtered;
    currentPage = 1; // Resetear a la primera página
    renderAppointments(filteredAppointments);
  }

  statusFilter.addEventListener('change', applyFilters);
  dateFilter.addEventListener('change', applyFilters);
  searchDocument.addEventListener('input', applyFilters);

  // Funciones de acción
  (window as any).startAppointment = async (appointmentId: number) => {
    const result = await (window as any).showSweetConfirm(
      '🩺 Iniciar Consulta',
      '¿Está seguro de que desea iniciar esta consulta?\n\nEsto marcará la cita como "En progreso" y comenzará el registro de la consulta médica.',
      '🩺 Sí, iniciar consulta',
      '❌ Cancelar'
    );

    if (!result.isConfirmed) return;

    try {
      const response = await fetch(`/api/doctor/appointments/${appointmentId}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'en_progreso' })
      });

      const updateResult = await response.json();

      if (updateResult.success) {
        showAlert('success', '¡Consulta iniciada!', 'La cita ahora está en progreso y puede comenzar el registro médico');
        
        // Recargar las citas
        loadAppointments();
      } else {
        showAlert('error', 'Error al iniciar consulta', updateResult.message || 'No se pudo iniciar la consulta');
      }
    } catch (error) {
      showAlert('error', 'Error de conexión', 'No se pudo conectar con el servidor');
    }
  };

  (window as any).viewPatientDetails = (patientId: number) => {
    // Ir a la página de paciente para doctores
    window.location.href = `/doctor/patients/${patientId}`;
  };

  (window as any).viewMedicalRecord = (appointmentId: number) => {
    // TODO: Implementar vista de historial médico
    showAlert('info', 'Funcionalidad en desarrollo', 'El historial médico estará disponible próximamente');
  };

  // Cambiar estado de cita
  (window as any).changeAppointmentStatus = async (appointmentId: number, newStatus: string) => {
    const statusTexts: {[key: string]: string} = {
      'en_progreso': 'En progreso',
      'completada': 'Completada',
      'cancelada': 'Cancelada',
      'no_asistio': 'No asistió'
    };

    const statusIcons: {[key: string]: string} = {
      'en_progreso': '🟡',
      'completada': '✅',
      'cancelada': '❌',
      'no_asistio': '🚫'
    };

    const statusMessages: {[key: string]: string} = {
      'en_progreso': 'La cita se marcará como iniciada y en progreso',
      'completada': 'Se marcará como finalizada y completada exitosamente',
      'cancelada': 'La cita será cancelada y no se podrá revertir',
      'no_asistio': 'Se registrará que el paciente no asistió a la cita'
    };

    const result = await (window as any).showSweetConfirm(
      `${statusIcons[newStatus]} Cambiar Estado de Cita`,
      `¿Está seguro de que desea cambiar el estado?\n\n${statusMessages[newStatus]}\n\nNuevo estado: "${statusTexts[newStatus]}"`,
      `${statusIcons[newStatus]} Sí, cambiar estado`,
      '❌ Cancelar'
    );

    if (!result.isConfirmed) {
      return;
    }

    try {
      const response = await fetch(`/api/doctor/appointments/${appointmentId}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: newStatus })
      });

      let updateResult: any = null;

      try {
        updateResult = await response.json();
      } catch {
        updateResult = null;
      }

      if (!response.ok) {
        let message = updateResult?.message || 'No se pudo actualizar el estado';
        if (updateResult?.code === 'MISSING_MEDICAL_HISTORY') {
          message = 'No se puede completar la cita sin una historia médica registrada.';
        }
        showAlert('error', 'Error al actualizar', message);
        return;
      }

      if (updateResult && updateResult.success) {
        showAlert('success', '¡Estado actualizado!', `La cita ahora está "${statusTexts[newStatus]}"`);

        if (newStatus === 'completada') {
          setTimeout(async () => {
            const certResult = await (window as any).showSweetConfirm(
              '📄 Emitir Certificado',
              '¿Desea emitir el Certificado de Aptitud Laboral ahora?',
              'Sí, emitir ahora',
              'Después'
            );

            if (certResult.isConfirmed) {
              (window as any).openIssueModal(appointmentId);
            }
          }, 1500);
        }

        loadAppointments();
      } else {
        let message = updateResult?.message || 'No se pudo actualizar el estado';
        if (updateResult?.code === 'MISSING_MEDICAL_HISTORY') {
          message = 'No se puede completar la cita sin una historia médica registrada.';
        }
        showAlert('error', 'Error al actualizar', message);
      }
    } catch (error) {
      showAlert('error', 'Error de conexión', 'No se pudo conectar con el servidor');
    }
  };

  // Refresh button
  document.getElementById('refreshBtn')!.addEventListener('click', loadAppointments);

  // Botones de paginación
  document.getElementById('prevBtn')!.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderAppointments(filteredAppointments);
      // Scroll hacia arriba de la tabla
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  document.getElementById('nextBtn')!.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredAppointments.length / itemsPerPage);
    if (currentPage < totalPages) {
      currentPage++;
      renderAppointments(filteredAppointments);
      // Scroll hacia arriba de la tabla
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // Modal Functions
  (window as any).openIssueModal = function(appointmentId: number) {
      // Usar comparación laxa por si el ID viene como string
      const app = allAppointments.find(a => a.id == appointmentId);
      if (!app) {
        // Silently fail
        return;
      }

      // VALIDACIÓN: Verificar si la cita está completada antes de emitir certificado
      // Normalizar estado a minúsculas para evitar errores
      const status = (app.status || '').toLowerCase();
      
      if (status !== 'completada') {
        showAlert('warning', 'Cita no completada', 'Debe completar la cita médica (historia clínica) antes de emitir el certificado. Redirigiendo a la información del paciente...');
        
        setTimeout(() => {
          (window as any).viewPatientDetails(app.patient_id);
        }, 5000);
        return;
      }

      // Reset form and restrictions requirement
      (document.getElementById('issueForm') as HTMLFormElement).reset();
      (document.getElementById('modalRestrictions') as HTMLTextAreaElement).required = false;

      (document.getElementById('modalPatientId') as HTMLInputElement).value = app.patient_id;
      (document.getElementById('modalAppointmentId') as HTMLInputElement).value = app.id.toString();
      (document.getElementById('modalPatientName') as HTMLInputElement).value = app.patient_name;
      
      // Default dates
      const today = new Date().toISOString().split('T')[0];
      (document.getElementById('modalStart') as HTMLInputElement).value = today;
      const nextYear = new Date();
      nextYear.setFullYear(nextYear.getFullYear() + 1);
      (document.getElementById('modalEnd') as HTMLInputElement).value = nextYear.toISOString().split('T')[0];

      document.getElementById('issueModal')!.classList.remove('hidden');
  };

  // Dynamic validation for restrictions
  document.getElementById('modalAptitude')?.addEventListener('change', function(e) {
      const val = (e.target as HTMLSelectElement).value;
      const restrictionsArea = document.getElementById('modalRestrictions') as HTMLTextAreaElement;
      const restrictionsLabel = restrictionsArea.previousElementSibling as HTMLElement;
      
      if (val === 'apto_con_restricciones') {
          restrictionsArea.required = true;
          restrictionsArea.placeholder = "Debe especificar las restricciones para este tipo de aptitud.";
          if (!restrictionsLabel.innerHTML.includes('*')) {
              restrictionsLabel.innerHTML += ' <span class="text-red-500">*</span>';
          }
      } else {
          restrictionsArea.required = false;
          restrictionsArea.placeholder = "Describa las restricciones si aplica...";
          restrictionsLabel.innerHTML = restrictionsLabel.innerHTML.replace(' <span class="text-red-500">*</span>', '');
      }
  });

  (window as any).closeModal = function() {
      document.getElementById('issueModal')!.classList.add('hidden');
      (document.getElementById('issueForm') as HTMLFormElement).reset();
  };

  (window as any).handleIssueSubmit = async function(e: Event) {
      e.preventDefault();
      
      const formData = {
          patient_id: (document.getElementById('modalPatientId') as HTMLInputElement).value,
          appointment_id: (document.getElementById('modalAppointmentId') as HTMLInputElement).value,
          aptitude_status: (document.getElementById('modalAptitude') as HTMLSelectElement).value,
          restrictions: (document.getElementById('modalRestrictions') as HTMLTextAreaElement).value,
          recommendations: (document.getElementById('modalRecommendations') as HTMLTextAreaElement).value,
          validity_start: (document.getElementById('modalStart') as HTMLInputElement).value,
          validity_end: (document.getElementById('modalEnd') as HTMLInputElement).value
      };

      try {
          const btn = (e.target as Element).querySelector('button[type="submit"]') as HTMLButtonElement;
          btn.innerText = 'Emitiendo...';
          btn.disabled = true;

          const response = await fetch('/api/doctor/certificates/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
              await showAlert('success', 'Certificado emitido exitosamente', 'Se abrirá el PDF a continuación.');
              (window as any).closeModal();

              // Abrir PDF en nueva pestaña inmediatamente
              if (result.data && result.data.verification_url) {
                   const code = result.data.verification_url.split('code=')[1];
                   if (code) {
                      window.open(`/api/certificates/download?code=${code}`, '_blank');
                   }
              }

              loadAppointments(); // Recargar lista para actualizar estado
          } else {
              showAlert('error', 'Error', result.message);
          }
      } catch (error) {
          showAlert('error', 'Error', 'Error al procesar la solicitud');
      } finally {
          const btn = (e.target as Element).querySelector('button[type="submit"]') as HTMLButtonElement;
          if(btn) {
              btn.innerText = 'Emitir y Finalizar';
              btn.disabled = false;
          }
      }
  };

  // Cargar datos iniciales
  loadAppointments();
</script>
