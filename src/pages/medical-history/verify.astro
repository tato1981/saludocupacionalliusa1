---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Verificar Historia Médica Ocupacional">
  <div class="bg-gradient-to-br from-emerald-50 to-green-100 min-h-screen">
    <div class="bg-white border-b border-gray-200 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-emerald-600 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m1-5a2 2 0 012 2v12a2 2 0 01-2 2H8l-4 4V5a2 2 0 012-2h10z"></path>
              </svg>
            </div>
            <div>
              <h1 class="text-xl font-bold text-gray-900">Verificación de Historia Médica Ocupacional</h1>
              <p class="text-sm text-gray-600">Sistema de Salud Ocupacional</p>
            </div>
          </div>
          <button onclick="window.location.href='/'" class="text-gray-600 hover:text-gray-900 transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <div class="text-center mb-8">
          <div class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m2-3H7a2 2 0 00-2 2v11a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2z"></path>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Verificar Historia Médica</h2>
          <p class="text-gray-600">Ingresa el código de verificación que aparece junto al código QR</p>
        </div>
        
        <form id="verifyForm" class="space-y-6">
          <div>
            <label for="historyCode" class="block text-sm font-medium text-gray-700 mb-2">Código de verificación</label>
            <input 
              type="text" 
              id="historyCode" 
              placeholder="Ej: HM-ABC123XYZ789"
              class="w-full px-4 py-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-lg text-center"
              required
            />
          </div>
          <button 
            type="submit" 
            class="w-full bg-emerald-600 text-white py-4 px-6 rounded-lg font-semibold text-lg shadow-lg hover:bg-emerald-700 active:bg-emerald-800 transition-colors flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Verificar Historia Médica
          </button>
        </form>
      </div>

      <div id="result" class="hidden">
        <div id="statusBanner" class="rounded-xl border p-6 mb-6 shadow-lg">
          <div class="flex items-center gap-4">
            <span id="statusIcon" class="flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-xl">?</span>
            <div class="flex-1">
              <p id="statusTitle" class="font-bold text-xl mb-1"></p>
              <p id="statusSubtitle" class="text-sm"></p>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <div class="bg-gradient-to-r from-emerald-600 to-green-600 px-8 py-6">
            <h3 class="text-white text-xl font-bold">Historia Médica Ocupacional</h3>
            <p class="text-emerald-100 text-sm mt-1">Documento clínico verificado</p>
          </div>

          <div class="p-8 space-y-8">
            <div>
              <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                Paciente
              </h4>
              <div id="patientInfo" class="space-y-3"></div>
            </div>

            <div>
              <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m2 9H7a2 2 0 01-2-2V7a2 2 0 012-2h10a2 2 0 012 2v10z"></path>
                </svg>
                Consulta
              </h4>
              <div id="consultInfo" class="space-y-3"></div>
            </div>

            <div id="diagnosisSection">
              <h4 class="text-sm font-bold text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M9 8h6m5 12H4a2 2 0 01-2-2V6a2 2 0 012-2h5.586a1 1 0 01.707.293L16 8h4a2 2 0 012 2v10a2 2 0 01-2 2z"></path>
                </svg>
                Diagnóstico y Concepto
              </h4>
              <div id="diagnosisInfo" class="space-y-3"></div>
            </div>
          </div>

          <div class="px-8 py-6 bg-gray-50 border-t space-y-4">
            <button 
              id="downloadBtn" 
              class="w-full bg-emerald-600 text-white py-4 px-6 rounded-lg font-semibold text-lg flex items-center justify-center gap-3 hover:bg-emerald-700 transition-colors shadow-lg"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              Descargar PDF
            </button>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              <button 
                id="shareBtn" 
                class="bg-gray-100 text-gray-700 py-3 px-4 rounded-lg font-medium flex items-center justify-center gap-2 hover:bg-gray-200 transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
                </svg>
                Compartir
              </button>
              
              <button 
                id="printBtn" 
                class="bg-gray-100 text-gray-700 py-3 px-4 rounded-lg font-medium flex items-center justify-center gap-2 hover:bg-gray-200 transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
                </svg>
                Imprimir
              </button>
              
              <button 
                id="newVerifyBtn" 
                class="bg-gray-100 text-gray-700 py-3 px-4 rounded-lg font-medium flex items-center justify-center gap-2 hover:bg-gray-200 transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Nuevo
              </button>
            </div>
          </div>
        </div>

        <div class="mt-6 p-4 bg-emerald-50 rounded-lg border border-emerald-200">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-sm text-emerald-800">
              Esta información permite verificar la autenticidad y datos generales de la historia médica ocupacional registrada en el sistema.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" is:inline></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      setupEventListeners();
      checkUrlParams();
    });

    function setupEventListeners() {
      document.getElementById('verifyForm').addEventListener('submit', handleVerifySubmit);
      document.getElementById('shareBtn').addEventListener('click', shareResult);
      document.getElementById('printBtn').addEventListener('click', () => window.print());
      document.getElementById('newVerifyBtn').addEventListener('click', resetVerify);
    }

    function checkUrlParams() {
      const params = new URLSearchParams(window.location.search);
      const rawCode = params.get('code');
      const code = rawCode ? rawCode.trim() : '';
      if (code !== '') {
        document.getElementById('historyCode').value = code;
        verifyHistory(code);
      }
    }

    async function handleVerifySubmit(e) {
      e.preventDefault();
      const code = document.getElementById('historyCode').value.trim();
      if (code) {
        await verifyHistory(code);
      }
    }

    async function verifyHistory(code) {
      showLoading(true);
      
      try {
        const response = await fetch(`/api/medical-history/verify?code=${encodeURIComponent(code)}`);
        const data = await response.json();
        
        showLoading(false);
        
        if (data.success && data.data) {
          displayHistory(data.data, code);
        } else {
          showError(data.message || 'Historia médica no encontrada');
        }
      } catch (error) {
        showLoading(false);
        showError('Error al verificar la historia médica. Verifica tu conexión.');
      }
    }

    function displayHistory(history, code) {
      document.getElementById('result').classList.remove('hidden');
      
      const statusBanner = document.getElementById('statusBanner');
      const statusIcon = document.getElementById('statusIcon');
      const statusTitle = document.getElementById('statusTitle');
      const statusSubtitle = document.getElementById('statusSubtitle');
      
      statusBanner.className = 'rounded-xl border p-6 mb-6 shadow-lg bg-emerald-50 border-emerald-200';
      statusIcon.className = 'flex-shrink-0 w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-xl bg-emerald-600';
      statusIcon.textContent = '✓';
      statusTitle.textContent = 'Historia Médica Válida';
      statusTitle.className = 'font-bold text-xl mb-1 text-emerald-800';
      statusSubtitle.textContent = 'La verificación fue exitosa';
      statusSubtitle.className = 'text-sm text-emerald-700';

      const patientInfo = document.getElementById('patientInfo');
      const birthDate = history.patient_birth_date ? new Date(history.patient_birth_date).toLocaleDateString('es-ES') : null;
      patientInfo.innerHTML = `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Nombre:</span>
          <span class="text-gray-900">${history.patient_name || 'N/A'}</span>
        </div>
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Documento:</span>
          <span class="text-gray-900">${history.document_type || ''} ${history.document_number || ''}</span>
        </div>
        ${history.company ? `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Empresa:</span>
          <span class="text-gray-900">${history.company}</span>
        </div>` : ''}
        ${birthDate ? `
        <div class="flex justify-between py-2">
          <span class="font-medium text-gray-700">Fecha de nacimiento:</span>
          <span class="text-gray-900">${birthDate}</span>
        </div>` : ''}
      `;

      const consultInfo = document.getElementById('consultInfo');
      const consultDateSource = history.appointment_date || history.created_at;
      const consultDate = consultDateSource
        ? new Date(consultDateSource).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' })
        : 'N/A';

      const appointmentTypeMap = {
        'examen_periodico': 'Examen Médico Periódico',
        'examen_ingreso': 'Examen de Ingreso',
        'examen_egreso': 'Examen de Egreso',
        'examen_reintegro': 'Examen de Reintegro',
        'consulta_general': 'Consulta General',
        'consulta_especializada': 'Consulta Especializada',
        'seguimiento': 'Seguimiento',
        'urgencias': 'Urgencias'
      };
      const appointmentTypeText = history.appointment_type ? (appointmentTypeMap[history.appointment_type] || history.appointment_type) : null;

      const nextAppointment = history.next_appointment_date
        ? new Date(history.next_appointment_date).toLocaleDateString('es-ES')
        : null;

      consultInfo.innerHTML = `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Fecha de consulta:</span>
          <span class="text-gray-900">${consultDate}</span>
        </div>
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Médico:</span>
          <span class="text-gray-900">${history.doctor_name || 'N/A'}</span>
        </div>
        ${history.doctor_specialization ? `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Especialidad:</span>
          <span class="text-gray-900">${history.doctor_specialization}</span>
        </div>` : ''}
        ${appointmentTypeText ? `
        <div class="flex justify-between py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Tipo de cita:</span>
          <span class="text-gray-900">${appointmentTypeText}</span>
        </div>` : ''}
        ${nextAppointment ? `
        <div class="flex justify-between py-2">
          <span class="font-medium text-gray-700">Próxima cita sugerida:</span>
          <span class="text-gray-900">${nextAppointment}</span>
        </div>` : ''}
      `;

      const diagnosisInfo = document.getElementById('diagnosisInfo');

      const statusMap = {
        'apto': { text: 'APTO PARA EL TRABAJO', color: 'text-green-700 bg-green-100' },
        'apto_con_restricciones': { text: 'APTO CON RESTRICCIONES', color: 'text-yellow-700 bg-yellow-100' },
        'apto_manipulacion_alimentos': { text: 'APTO PARA MANIPULACIÓN DE ALIMENTOS', color: 'text-blue-700 bg-blue-100' },
        'apto_trabajo_alturas': { text: 'APTO PARA TRABAJO EN ALTURAS', color: 'text-purple-700 bg-purple-100' },
        'apto_espacios_confinados': { text: 'APTO PARA ESPACIOS CONFINADOS', color: 'text-indigo-700 bg-indigo-100' },
        'apto_conduccion': { text: 'APTO PARA CONDUCCIÓN', color: 'text-teal-700 bg-teal-100' }
      };
      const status = history.aptitude_status ? (statusMap[history.aptitude_status] || { text: history.aptitude_status, color: 'text-gray-700 bg-gray-100' }) : null;

      diagnosisInfo.innerHTML = `
        ${status ? `
        <div class="mb-4">
          <span class="inline-block px-4 py-2 rounded-full text-sm font-semibold ${status.color}">${status.text}</span>
        </div>` : ''}
        <div class="py-2 border-b border-gray-100">
          <span class="block font-medium text-gray-700 mb-1">Diagnóstico principal:</span>
          <p class="text-gray-900">${history.diagnosis || 'N/A'}</p>
        </div>
        ${history.cie10_code ? `
        <div class="py-2 border-b border-gray-100">
          <span class="font-medium text-gray-700">Código CIE-10:</span>
          <span class="ml-2 text-gray-900">${history.cie10_code}</span>
        </div>` : ''}
        ${history.recommendations ? `
        <div class="py-2 border-b border-gray-100">
          <span class="block font-medium text-gray-700 mb-1">Recomendaciones:</span>
          <p class="text-gray-900 whitespace-pre-line">${history.recommendations}</p>
        </div>` : ''}
        ${history.restrictions ? `
        <div class="py-2">
          <span class="block font-medium text-gray-700 mb-1">Restricciones:</span>
          <p class="text-gray-900 whitespace-pre-line">${history.restrictions}</p>
        </div>` : ''}
      `;

      const downloadBtn = document.getElementById('downloadBtn');
      downloadBtn.onclick = async () => {
        try {
          showLoading(true);
          const response = await fetch(`/api/medical-history/download?code=${encodeURIComponent(code)}`);
          
          if (!response.ok) {
            throw new Error('Error al descargar la historia médica');
          }

          const blob = await response.blob();
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `historia_medica_${code}.pdf`;
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(url);
          document.body.removeChild(a);
          
          showLoading(false);
          
          Swal.fire({
            icon: 'success',
            title: 'Descarga exitosa',
            text: 'La historia médica se ha descargado correctamente',
            timer: 2000,
            showConfirmButton: false
          });
        } catch (error) {
          showLoading(false);
          Swal.fire({
            icon: 'error',
            title: 'Error de descarga',
            text: 'No se pudo descargar la historia médica. Intenta nuevamente.',
            confirmButtonText: 'Entendido'
          });
        }
      };

      setTimeout(() => {
        document.getElementById('result').scrollIntoView({ 
          behavior: 'smooth', 
          block: 'start' 
        });
      }, 100);

      Swal.fire({
        icon: 'success',
        title: 'Historia médica verificada',
        text: 'La historia médica es válida y auténtica',
        timer: 2000,
        showConfirmButton: false
      });
    }

    function showError(message) {
      document.getElementById('result').classList.add('hidden');
      
      Swal.fire({
        icon: 'error',
        title: 'Verificación fallida',
        text: message,
        confirmButtonText: 'Entendido'
      });
    }

    function showLoading(show) {
      const button = document.querySelector('#verifyForm button[type="submit"]');
      
      if (show) {
        if (button) {
          button.disabled = true;
          button.innerHTML = `
            <svg class="animate-spin w-5 h-5" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="m4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Verificando...
          `;
        }
      } else {
        if (button) {
          button.disabled = false;
          button.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Verificar Historia Médica
          `;
        }
      }
    }

    async function shareResult() {
      const code = document.getElementById('historyCode').value.trim();
      const url = `${window.location.origin}/medical-history/verify?code=${encodeURIComponent(code)}`;
      
      if (navigator.share) {
        try {
          await navigator.share({
            title: 'Historia Médica Ocupacional',
            text: 'Verificación de historia médica ocupacional',
            url: url
          });
        } catch (error) {
          if (error.name !== 'AbortError') {
            copyToClipboard(url);
          }
        }
      } else {
        copyToClipboard(url);
      }
    }

    async function copyToClipboard(text) {
      try {
        await navigator.clipboard.writeText(text);
        Swal.fire({
          icon: 'success',
          title: 'Enlace copiado',
          text: 'El enlace se ha copiado al portapapeles',
          timer: 2000,
          showConfirmButton: false
        });
      } catch (error) {
        Swal.fire({
          icon: 'info',
          title: 'Enlace disponible',
          text: text,
          confirmButtonText: 'Cerrar'
        });
      }
    }

    function resetVerify() {
      document.getElementById('result').classList.add('hidden');
      document.getElementById('historyCode').value = '';
      document.getElementById('historyCode').focus();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  </script>
</Layout>

